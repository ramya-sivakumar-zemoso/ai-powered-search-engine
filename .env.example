# ── Meilisearch ───────────────────────────────────────────────────────────────
# Start binary: ./meilisearch --master-key your_key_here
MEILI_URL=http://127.0.0.1:7700
MEILI_MASTER_KEY=your_meilisearch_master_key_here
MEILI_INDEX_NAME=movies
# Must match a key under GET /indexes/{uid}/settings/embedders (hybrid/semantic search).
# setup_index registers this name when using the HuggingFace embedder (default: default).
MEILI_EMBEDDER_NAME=default

# ── OpenAI (used by LLM nodes in Phase 2+ — NOT for embeddings) ───────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Embeddings ────────────────────────────────────────────────────────────────
# Used by: setup_index — Meilisearch "huggingFace" embedder (model + dimensions must match EMBEDDING_*).
# Meilisearch downloads HF weights on first use. No API key needed for HuggingFace public models.
# If your index uses a different Meilisearch embedder (e.g. OpenAI in the Meili dashboard),
# set MEILI_EMBEDDER_NAME to that embedder's name; changing EMBEDDING_* does not reconfigure Meili.
# NOTE: After changing EMBEDDING_MODEL, you MUST re-index: python -m src.tools.setup_index
#       Vectors from different models are NOT compatible — old index must be rebuilt.
#
# Active model: EmbeddingGemma 300M (google/embeddinggemma-300m)
#   - 308M params, 768-dim output, 2K token context, 100+ languages
#   - ~300 MB download (vs ~2.2 GB for multilingual-e5-large)
#   - Estimated reindex time for 10k docs: ~2 min CPU / ~15 sec GPU
#   - Previous model: intfloat/multilingual-e5-large (1024 dims)
EMBEDDING_MODEL=google/embeddinggemma-300m
EMBEDDING_DIMENSIONS=768

# ── Dataset ingestion ─────────────────────────────────────────────────────────
# Run: python -m src.tools.setup_index  (optional: --file, --schema, --limit)
# Formats: .json (array), .jsonl, .csv, .tsv — mapping via src/models/schema_registry.py
DATASET_FILE=data/movies.json
# Selects ``DatasetSchema`` in src/models/schema_registry.py: movies | marketplace | sports
DATASET_SCHEMA=movies

# ── LangWatch observability ─────────────────────────
LANGWATCH_API_KEY=your_langwatch_api_key_here
LANGWATCH_PROJECT=novamart-search
LANGWATCH_ENABLED=true

# ── Pipeline tuning ───────────────────────────────────────────────────────────
MAX_SEARCH_ITERATIONS=3
TOKEN_BUDGET_USD=0.02
RERANKER_TOP_N=10
# Multilingual cross-encoder reranker (sentence-transformers CrossEncoder). Override for a different HF model id if needed.
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CONFIDENCE_THRESHOLD_DEGRADED=0.30
NEAR_DUPLICATE_THRESHOLD=0.92

# ── Injection detection ───────────────────────────────────────────────────────
INJECTION_SCAN_THRESHOLD=0.85

# ── Freshness thresholds (seconds) ────────────────────────────────────────────
FRESHNESS_THRESHOLD_SECONDS=300
STALENESS_THRESHOLD_SECONDS=3600

# ── Performance / latency ─────────────────────────────────────────────────────
# fast_mode=true skips LLM explanation generation in the reranker.
# Reduces end-to-end latency by ~400-800 ms. Cross-encoder re-ranking still runs.
# Use for latency-sensitive paths; set false (default) for full AI pipeline.
FAST_MODE=false

# ── Kafka / Redpanda streaming ingest ─────────────────────────────────────────
# Set KAFKA_ENABLED=true to activate the Kafka consumer path alongside the
# FastAPI ingest endpoint. Compatible with Apache Kafka, Redpanda, Confluent Cloud.
#
# Local dev (Docker):
#   docker run -d -p 9092:9092 --name redpanda \
#     redpandadata/redpanda:latest redpanda start --overprovisioned \
#     --smp 1 --memory 1G --reserve-memory 0M --node-id 0 \
#     --check=false --kafka-addr 0.0.0.0:9092
#
# Managed (Redpanda Serverless / Confluent Cloud): set KAFKA_SECURITY_PROTOCOL=SASL_SSL
# and fill in SASL credentials below.
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=search-ingest
KAFKA_CONSUMER_GROUP=search-engine-consumer
# PLAINTEXT for local dev; SASL_SSL for Redpanda Serverless / Confluent Cloud
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
# Max documents processed per consumer poll cycle (keep low for 5-min SLA assurance)
KAFKA_MAX_POLL_RECORDS=10