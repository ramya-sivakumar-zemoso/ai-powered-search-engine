# ── Meilisearch ───────────────────────────────────────────────────────────────
# Start binary: ./meilisearch --master-key your_key_here
MEILI_URL=http://127.0.0.1:7700
MEILI_MASTER_KEY=your_meilisearch_master_key_here
MEILI_INDEX_NAME=movies
# Must match a key under GET /indexes/{uid}/settings/embedders (hybrid/semantic search).
# setup_index registers this name when using the HuggingFace embedder (default: default).
MEILI_EMBEDDER_NAME=default

# ── OpenAI (used by LLM nodes in Phase 2+ — NOT for embeddings) ───────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Embeddings ────────────────────────────────────────────────────────────────
# Used by: setup_index — Meilisearch "huggingFace" embedder (model + dimensions must match EMBEDDING_*).
# Meilisearch downloads HF weights on first use. No API key needed for HuggingFace public models.
# If your index uses a different Meilisearch embedder (e.g. OpenAI in the Meili dashboard),
# set MEILI_EMBEDDER_NAME to that embedder's name; changing EMBEDDING_* does not reconfigure Meili.
# NOTE: After changing EMBEDDING_MODEL, you MUST re-index: python -m src.tools.setup_index
#       Vectors from different models are NOT compatible — old index must be rebuilt.
#
# Active model: multilingual-e5-large (intfloat/multilingual-e5-large)
#   - 560M params, 1024-dim output, multilingual retrieval
#   - Served via Kaggle + ngrok (EMBEDDER_SOURCE=self_hosted)
# Embedder source options: local | openai | gemini | self_hosted
#   local:       Meilisearch built-in HuggingFace inference (BERT-family only)
#   self_hosted:  external OpenAI-compatible server (TEI / Kaggle + ngrok)
#   openai:      OpenAI Embeddings API
#   gemini:      Gemini Developer API (batchEmbedContents)
EMBEDDER_SOURCE=self_hosted
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSIONS=1024
# Used when EMBEDDER_SOURCE=self_hosted (Meilisearch calls <url>/v1/embeddings)
EMBEDDING_SERVER_URL=http://localhost:8080
# Used when EMBEDDER_SOURCE=gemini
GEMINI_API_KEY=
GEMINI_EMBEDDING_TASK_TYPE=
GEMINI_EMBEDDING_MAX_OUTPUT_DIMENSION=3072
# Optional: ngrok auth token for Kaggle helper (scripts/kaggle_e5_ngrok_server.py)
NGROK_AUTHTOKEN=

# ── Dataset ingestion ─────────────────────────────────────────────────────────
# Run: python -m src.tools.setup_index  (optional: --file, --schema, --limit)
# Formats: .json (array), .jsonl, .csv, .tsv — mapping via src/models/schema_registry.py
DATASET_FILE=data/movies.json
# Selects ``DatasetSchema`` in src/models/schema_registry.py: movies | marketplace | sports
DATASET_SCHEMA=movies

# ── Live ingest SLA (real-time path — not setup_index) ────────────────────────
# Max seconds to wait for Meilisearch indexing task success after POST /ingest/*
# or after Kafka consumer calls upsert. Breach → HTTP 408 (ingest API) or Kafka
# batch retry (no offset commit). Typical completion is far below this ceiling.
# GET /ingest/health returns machine-readable sla_contract for monitors and contracts.
INGEST_SLA_SECONDS=300

# ── LangWatch observability ─────────────────────────
LANGWATCH_API_KEY=your_langwatch_api_key_here
LANGWATCH_PROJECT=novamart-search
LANGWATCH_ENABLED=true

# ── Pipeline tuning ───────────────────────────────────────────────────────────
# Max evaluator-triggered retries (extra search rounds after the first). Value 3 ⇒ up to 4 searches total.
MAX_SEARCH_ITERATIONS=3
TOKEN_BUDGET_USD=0.02
RERANKER_TOP_N=10
# Multilingual cross-encoder reranker (sentence-transformers CrossEncoder). Override for a different HF model id if needed.
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CONFIDENCE_THRESHOLD_DEGRADED=0.30
NEAR_DUPLICATE_THRESHOLD=0.92

# ── Injection detection ───────────────────────────────────────────────────────
INJECTION_SCAN_THRESHOLD=0.85

# ── Freshness thresholds (seconds) ────────────────────────────────────────────
FRESHNESS_THRESHOLD_SECONDS=300
STALENESS_THRESHOLD_SECONDS=3600

# ── Performance / latency ─────────────────────────────────────────────────────
# fast_mode=true skips LLM explanation generation in the reranker.
# Reduces end-to-end latency by ~400-800 ms. Cross-encoder re-ranking still runs.
# Use for latency-sensitive paths; set false (default) for full AI pipeline.
FAST_MODE=false
# Use Python rule-table routing instead of GPT in retrieval_router (lower latency and cost).
ROUTER_USE_LLM=false
# Preload heavy local models on process startup (injection scanner + cross-encoder).
WARMUP_MODELS_ON_START=true
# Non-blocking explanation mode (recommended for best perceived latency):
# - true: return ranked results immediately, generate explanations asynchronously
# - false: block response until explanations are generated
RERANKER_EXPLAIN_ASYNC=true
# Explain only top-K reranked results to reduce tail latency/cost.
RERANKER_EXPLAIN_TOP_K=5
# Strict timeout/retries for explanation call (interactive user path).
RERANKER_EXPLAIN_TIMEOUT_SECONDS=10
RERANKER_EXPLAIN_MAX_RETRIES=0

# ── Kafka / Redpanda streaming ingest ─────────────────────────────────────────
# Set KAFKA_ENABLED=true to activate the Kafka consumer path alongside the
# FastAPI ingest endpoint. Compatible with Apache Kafka, Redpanda, Confluent Cloud.
#
# Local dev (Docker):
#   docker run -d -p 9092:9092 --name redpanda \
#     redpandadata/redpanda:latest redpanda start --overprovisioned \
#     --smp 1 --memory 1G --reserve-memory 0M --node-id 0 \
#     --check=false --kafka-addr 0.0.0.0:9092
#
# Managed (Redpanda Serverless / Confluent Cloud): set KAFKA_SECURITY_PROTOCOL=SASL_SSL
# and fill in SASL credentials below.
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=search-ingest
KAFKA_CONSUMER_GROUP=search-engine-consumer
# PLAINTEXT for local dev; SASL_SSL for Redpanda Serverless / Confluent Cloud
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
# Documents per poll: lower (e.g. 1) = less batching delay before Meilisearch upsert;
# higher = fewer Meilisearch API calls. Consumer still waits for task success per batch.
KAFKA_MAX_POLL_RECORDS=10